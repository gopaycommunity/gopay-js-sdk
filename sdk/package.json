{
    "name": "gopay-js-sdk",
    "version": "1.1.0",
    "description": "GoPay JavaScript SDK for browser and Node.js",
    "keywords": [
        "gopay",
        "payment",
        "sdk",
        "javascript",
        "typescript"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=20.12.0"
    },
    "packageManager": "yarn@4.7.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "check:circular": "madge --circular --extensions ts --ts-config tsconfig.json src/",
        "check:exports": "ts-unused-exports tsconfig.json --excludePathsFromReport='src/index' --ignoreFiles='types/generated'",
        "codegen": "openapi-typescript ../Payments.yaml -o src/types/generated.ts"
    },
    "devDependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^24.12.0",
        "@vitest/coverage-v8": "^4.1.0",
        "jsdom": "^29.0.1",
        "madge": "^8.0.0",
        "openapi-typescript": "^7.13.0",
        "semantic-release": "^25.0.3",
        "ts-unused-exports": "^11.0.1",
        "tsup": "^8.5.1",
        "typescript": "~5.9.3",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "ky": "^1.14.3"
    }
}
