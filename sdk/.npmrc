# @semantic-release/npm v12 handles workspace packages natively via --workspace <pkgName>.
# Do NOT add workspaces=false here — that flag conflicts with --workspace and causes
# "Can not use --no-workspaces and --workspace at the same time" during verifyConditions.
# @gopay-internal/core is a devDependency only (bundled via noExternal in tsup.config.ts,
# not published to npm), so workspace protocol resolution does not affect the published package.
