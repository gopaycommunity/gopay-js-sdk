{
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedImports": {
                    "level": "error",
                    "fix": "safe"
                }
            },
            "style": {
                "useBlockStatements": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single"
        }
    },
    "json": {
        "formatter": {
            "enabled": true
        }
    },
    "files": {
        "includes": [
            "**",
            "!**/dist",
            "!**/node_modules",
            "!**/.yarn",
            "!**/CHANGELOG.md",
            "!**/coverage",
            "!**/playwright-report",
            "!**/test-results",
            "!.claude/worktrees",
            "!sdk/src/types/generated.ts",
            "!browser-sdk/src/types/generated.ts",
            "!internal/core/src/types/generated.ts",
            "!example/iframe/index.html"
        ]
    }
}
