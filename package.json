{
    "name": "gp-gw-js-sdk-root",
    "private": true,
    "packageManager": "yarn@4.13.0",
    "workspaces": [
        "sdk"
    ],
    "scripts": {
        "lint": "biome check .",
        "ci": "yarn biome ci . && yarn workspace gopay-js-sdk run typecheck",
        "prepare": "husky",
        "test:browser": "yarn workspace gopay-js-sdk run build && playwright test",
        "example": "yarn workspace gopay-js-sdk run build && node example/serve.js"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.8",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@playwright/test": "^1.58.2",
        "husky": "^9.1.7",
        "serve": "^14.2.6"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "parserPreset": {
            "parserOpts": {
                "issuePrefixes": [
                    "GPOMA-"
                ]
            }
        },
        "rules": {
            "references-empty": [
                2,
                "never"
            ]
        }
    }
}
